<?xml version="1.0" encoding="utf-8" ?>
<!--
  ============================================
  NuVatis 사용자 매퍼 XML - 완전 학습 가이드
  ============================================

  【 NuVatis란? 】
  - MyBatis 스타일의 XML 기반 SQL 매퍼 프레임워크
  - .NET용으로 포팅된 MyBatis (Java)
  - XML 파일에 SQL을 작성하고, C# 인터페이스로 매핑
  - Source Generator가 자동으로 구현체 생성 (런타임 오버헤드 없음)

  【 왜 XML 매퍼를 사용하나? 】
  - SQL 중앙 관리: 코드와 SQL 분리, 유지보수 용이
  - 동적 SQL: if, foreach, where 등으로 복잡한 쿼리 구성
  - 타입 안전성: C# 인터페이스로 컴파일 타임 체크
  - 성능: Source Generator로 코드 생성, 리플렉션 없음

  【 기본 구조 】
  1. XML 파일: SQL 쿼리 정의 (이 파일)
  2. C# 인터페이스: 메서드 시그니처 정의 (IUserMapper.cs)
  3. Source Generator: 자동으로 구현체 생성 (빌드 시)
  4. DI 컨테이너: 인터페이스 주입받아 사용

  작성자: 최진호
  작성일: 2026-03-01
-->
<mapper namespace="NuVatis.Sample.Core.Mappers.IUserMapper">

  <!--
    ==========================================
    캐시 설정 (Cache Configuration)
    ==========================================

    【 캐시란? 】
    - 쿼리 결과를 메모리에 저장하여 재사용
    - 동일한 쿼리 반복 실행 시 DB 접근 없이 즉시 반환
    - 읽기 전용 데이터에 효과적 (예: 국가 코드, 카테고리)

    【 속성 설명 】
    - eviction: 캐시 제거 정책
      * LRU (Least Recently Used): 가장 오래 사용 안 한 것부터 제거 [권장]
      * FIFO (First In First Out): 먼저 들어온 것부터 제거
      * SOFT: JVM Soft Reference 사용 (메모리 부족 시 자동 제거)
      * WEAK: JVM Weak Reference 사용 (GC 시 제거)

    - flushInterval: 캐시 초기화 주기 (밀리초)
      * 600000 = 10분마다 캐시 전체 삭제
      * INSERT/UPDATE/DELETE 실행 시에도 자동 초기화

    - size: 최대 캐시 항목 수
      * 512개를 초과하면 LRU 정책에 따라 제거

    【 주의사항 】
    - 자주 변경되는 데이터는 캐시 비활성화
    - INSERT/UPDATE/DELETE 후 캐시 자동 무효화됨
    - 분산 환경에서는 캐시 동기화 문제 주의
  -->
  <cache eviction="LRU" flushInterval="600000" size="512" />

  <!--
    ==========================================
    ResultMap 정의 (DB 컬럼 → C# 속성 매핑)
    ==========================================

    【 ResultMap이란? 】
    - SQL 쿼리 결과(컬럼)를 C# 객체(속성)로 매핑하는 규칙
    - 컬럼명과 속성명이 다를 때 필수
    - 1:1, 1:N 관계 매핑 가능 (association, collection)

    【 왜 필요한가? 】
    - DB: snake_case (user_name, created_at)
    - C#: PascalCase (UserName, CreatedAt)
    - 수동 매핑 없이 자동 변환

    【 태그 설명 】
    - <id>: Primary Key 컬럼 (성능 최적화, 중복 제거)
    - <result>: 일반 컬럼 매핑
    - <association>: 1:1 관계 (예: User → Address)
    - <collection>: 1:N 관계 (예: User → List<Order>)

    【 속성 설명 】
    - id: ResultMap 고유 식별자 (select 태그에서 참조)
    - type: 매핑할 C# 타입 (Full Qualified Name)
    - column: DB 컬럼명
    - property: C# 속성명

    【 사용 예시 】
    SQL: SELECT id, user_name, email FROM users WHERE id = 1
    결과:
      id=1, user_name="john", email="john@example.com"

    ResultMap 적용 후:
      new User { Id=1, UserName="john", Email="john@example.com" }
  -->
  <resultMap id="UserResult" type="NuVatis.Sample.Core.Models.User">
    <!→ Primary Key: 성능 최적화를 위해 <id> 태그 사용 -->
    <id column="id" property="Id" />

    <!→ 일반 컬럼: DB snake_case → C# PascalCase 자동 변환 -->
    <result column="user_name" property="UserName" />
    <result column="email" property="Email" />
    <result column="full_name" property="FullName" />
    <result column="created_at" property="CreatedAt" />
    <result column="updated_at" property="UpdatedAt" />
    <result column="is_active" property="IsActive" />
  </resultMap>

  <!--
    ==========================================
    쿼리 1: ID로 사용자 조회 (동기)
    ==========================================

    【 사용 목적 】
    - 단일 사용자 상세 정보 조회
    - Primary Key로 조회 (가장 빠름, 인덱스 활용)

    【 SQL 문법 】
    - SELECT: 조회할 컬럼 명시
    - FROM: 테이블 지정
    - WHERE: 조건 지정 (id = 특정 값)

    【 파라미터 바인딩 】
    - #{Id}: C# 메서드 파라미터 'id'를 SQL에 바인딩
    - PreparedStatement 사용 → SQL Injection 방지
    - 타입 안전: int, string, DateTime 등 자동 변환

    【 성능 】
    - Primary Key 조회: O(1) ~ O(log n) (B-Tree 인덱스)
    - 응답 시간: <1ms (인덱스 있을 때)

    【 C# 사용 예시 】
    var user = _userMapper.GetById(123);
    if (user != null)
    {
        Console.WriteLine($"이름: {user.FullName}");
    }
  -->
  <select id="GetById" resultMap="UserResult">
    SELECT id, user_name, email, full_name, created_at, updated_at, is_active
    FROM users
    WHERE id = #{Id}
  </select>

  <!--
    ==========================================
    쿼리 2: ID로 사용자 조회 (비동기)
    ==========================================

    【 동기 vs 비동기 】
    - 동기 (GetById): 결과 반환까지 스레드 블로킹
    - 비동기 (GetByIdAsync): 스레드 반환, Task로 완료 대기

    【 비동기의 장점 】
    - 스레드 효율성: I/O 대기 중 다른 작업 처리 가능
    - 확장성: 동시 요청 수 증가 시 성능 저하 적음
    - ASP.NET Core: 비동기 권장 (요청당 스레드 절약)

    【 언제 사용? 】
    - Web API: 항상 비동기 사용 [권장]
    - 콘솔 앱: 단순 스크립트는 동기 사용 가능
    - 배치 작업: 병렬 처리 시 비동기 사용

    【 C# 사용 예시 】
    var user = await _userMapper.GetByIdAsync(123);

    【 주의사항 】
    - async/await 키워드 필수
    - ConfigureAwait(false) 고려 (ASP.NET Core는 불필요)
  -->
  <select id="GetByIdAsync" resultMap="UserResult">
    SELECT id, user_name, email, full_name, created_at, updated_at, is_active
    FROM users
    WHERE id = #{Id}
  </select>

  <!--
    ==========================================
    쿼리 3: 모든 사용자 조회
    ==========================================

    【 사용 목적 】
    - 전체 사용자 목록 조회
    - 관리자 페이지, 통계 등에 사용

    【 SQL 문법 】
    - ORDER BY: 정렬 기준 (created_at DESC = 최신순)
    - DESC: 내림차순 (큰 값 → 작은 값)
    - ASC: 오름차순 (작은 값 → 큰 값, 기본값)

    【 성능 주의 】
    - 전체 조회: 데이터 많을 때 느림 (100만 건 → 수 초)
    - 권장: LIMIT 사용하여 페이징 처리

    【 대안: 페이징 】
    LIMIT 100 OFFSET 0   → 첫 100개
    LIMIT 100 OFFSET 100 → 101~200번째

    【 C# 사용 예시 】
    var users = _userMapper.GetAll();
    foreach (var user in users)
    {
        Console.WriteLine(user.UserName);
    }

    【 주의사항 】
    - 데이터 10만 건 이상 시 페이징 필수
    - 메모리 부족 위험 (OutOfMemoryException)
  -->
  <select id="GetAll" resultMap="UserResult">
    SELECT id, user_name, email, full_name, created_at, updated_at, is_active
    FROM users
    ORDER BY created_at DESC
  </select>

  <!--
    ==========================================
    쿼리 4: 동적 검색 (MyBatis 핵심 기능)
    ==========================================

    【 동적 SQL이란? 】
    - 조건에 따라 SQL 쿼리를 동적으로 생성
    - 검색 조건이 선택적일 때 필수 (예: 고급 검색 폼)

    【 전통적인 방법의 문제점 】
    string sql = "SELECT * FROM users WHERE 1=1";
    if (!string.IsNullOrEmpty(userName))
        sql += " AND user_name LIKE @userName";
    if (!string.IsNullOrEmpty(email))
        sql += " AND email LIKE @email";

    문제:
    - 문자열 조작 → 가독성 나쁨
    - SQL Injection 위험
    - 유지보수 어려움

    【 NuVatis 동적 SQL 】
    - <where>: WHERE 절 자동 생성 (첫 번째 AND/OR 제거)
    - <if test="">: 조건부 SQL 조각 추가
    - <foreach>: 리스트를 IN 절로 변환

    【 태그 상세 설명 】

    1. <where> 태그
       - 자동으로 WHERE 절 생성
       - 첫 번째 조건의 AND/OR 자동 제거
       - 조건 없으면 WHERE 절 생략

       예시:
       <where>
         <if test="UserName != null">AND user_name = #{UserName}</if>
       </where>

       결과:
       - UserName이 null: (WHERE 절 없음)
       - UserName이 "john": WHERE user_name = 'john'

    2. <if test=""> 태그
       - test 조건이 true일 때만 SQL 조각 포함
       - 조건 문법: C# 표현식 (!=, ==, >, <, &&, ||)

       예시:
       <if test="UserName != null">
         AND user_name LIKE '%' || #{UserName} || '%'
       </if>

       결과:
       - UserName = null: (SQL 조각 제외)
       - UserName = "john": AND user_name LIKE '%john%'

    3. <foreach> 태그
       - 리스트를 IN 절로 변환
       - collection: C# 리스트 속성명
       - item: 반복 변수명
       - open/close: 시작/종료 문자
       - separator: 구분자

       예시:
       <foreach collection="Ids" item="id" open="(" separator="," close=")">
         #{id}
       </foreach>

       입력: Ids = [1, 2, 3]
       결과: (1, 2, 3)

    【 사용 시나리오 】
    - 검색 조건 1: 이름만 입력 → WHERE user_name LIKE '%john%'
    - 검색 조건 2: 이메일만 입력 → WHERE email LIKE '%@gmail.com%'
    - 검색 조건 3: 둘 다 입력 → WHERE user_name LIKE '%john%' AND email LIKE '%@gmail.com%'
    - 검색 조건 4: 아무것도 안 입력 → (WHERE 절 없음, 전체 조회)

    【 C# 사용 예시 】
    var param = new UserSearchParam
    {
        UserName = "john",    // 이름 검색
        Email = null,         // 이메일 조건 없음
        IsActive = true,      // 활성 사용자만
        Ids = new List<int> { 1, 2, 3 }  // ID 1, 2, 3만
    };
    var users = _userMapper.Search(param);

    생성되는 SQL:
    SELECT ... FROM users
    WHERE user_name LIKE '%john%'
      AND is_active = true
      AND id IN (1, 2, 3)
    ORDER BY created_at DESC
  -->
  <select id="Search" resultMap="UserResult">
    SELECT id, user_name, email, full_name, created_at, updated_at, is_active
    FROM users
    <where>
      <!→ 조건 1: 사용자명으로 검색 (부분 일치) -->
      <if test="UserName != null">
        AND user_name LIKE '%' || #{UserName} || '%'
      </if>

      <!→ 조건 2: 이메일로 검색 (부분 일치) -->
      <if test="Email != null">
        AND email LIKE '%' || #{Email} || '%'
      </if>

      <!→ 조건 3: 활성 상태 필터 -->
      <if test="IsActive != null">
        AND is_active = #{IsActive}
      </if>

      <!→ 조건 4: ID 목록으로 검색 (IN 절) -->
      <if test="Ids != null and Ids.Count > 0">
        AND id IN
        <foreach collection="Ids" item="id" open="(" separator="," close=")">
          #{id}
        </foreach>
      </if>
    </where>
    ORDER BY created_at DESC
  </select>

  <!--
    ==========================================
    쿼리 5: 페이징 검색 (비동기)
    ==========================================

    【 페이징이란? 】
    - 대량 데이터를 페이지 단위로 나눠서 조회
    - 성능 향상 + 사용자 경험 개선

    【 SQL 문법 】
    - LIMIT: 조회할 최대 행 수
    - OFFSET: 건너뛸 행 수

    예시:
    LIMIT 10 OFFSET 0   → 1~10번째 (1페이지)
    LIMIT 10 OFFSET 10  → 11~20번째 (2페이지)
    LIMIT 10 OFFSET 20  → 21~30번째 (3페이지)

    계산 공식:
    OFFSET = (페이지번호 - 1) × 페이지크기
    LIMIT = 페이지크기

    【 동적 LIMIT/OFFSET 】
    - <if test="Limit != null">: Limit이 null이 아닐 때만 적용
    - 페이징 없이 전체 조회 가능 (Limit=null, Offset=null)

    【 성능 최적화 】
    - OFFSET이 크면 느림 (OFFSET 100000 → 10만 건 건너뛰기)
    - 대안: Keyset Pagination (WHERE id > #{lastId} LIMIT 10)

    【 C# 사용 예시 】
    // 1페이지 (1~10번째)
    var param = new UserSearchParam
    {
        Limit = 10,
        Offset = 0
    };
    var users = await _userMapper.SearchWithPagingAsync(param);

    // 3페이지 (21~30번째)
    param.Offset = 20;  // (3-1) × 10
    users = await _userMapper.SearchWithPagingAsync(param);
  -->
  <select id="SearchWithPagingAsync" resultMap="UserResult">
    SELECT id, user_name, email, full_name, created_at, updated_at, is_active
    FROM users
    <where>
      <if test="UserName != null">
        AND user_name LIKE '%' || #{UserName} || '%'
      </if>
      <if test="Email != null">
        AND email LIKE '%' || #{Email} || '%'
      </if>
      <if test="IsActive != null">
        AND is_active = #{IsActive}
      </if>
      <if test="Ids != null and Ids.Count > 0">
        AND id IN
        <foreach collection="Ids" item="id" open="(" separator="," close=")">
          #{id}
        </foreach>
      </if>
    </where>
    ORDER BY created_at DESC
    <if test="Limit != null">
      LIMIT #{Limit}
    </if>
    <if test="Offset != null">
      OFFSET #{Offset}
    </if>
  </select>

  <!--
    ==========================================
    쿼리 6: 사용자 수 조회 (COUNT)
    ==========================================

    【 사용 목적 】
    - 검색 결과 총 개수 조회
    - 페이징 UI 표시 (예: "총 1,234건")

    【 SQL 문법 】
    - COUNT(*): 전체 행 수 카운트
    - AS count: 컬럼명을 'count'로 별칭 지정

    【 resultType vs resultMap 】
    - resultType: 단순 타입 (int, string, DateTime)
    - resultMap: 복잡한 객체 (User, Order 등)

    이 쿼리는 int 하나만 반환 → resultType="int"

    【 C# 사용 예시 】
    var param = new UserSearchParam { UserName = "john" };
    int totalCount = _userMapper.Count(param);

    int totalPages = (int)Math.Ceiling(totalCount / 10.0);
    Console.WriteLine($"총 {totalCount}건, {totalPages}페이지");
  -->
  <select id="Count" resultType="int">
    SELECT COUNT(*) AS count
    FROM users
    <where>
      <if test="UserName != null">
        AND user_name LIKE '%' || #{UserName} || '%'
      </if>
      <if test="Email != null">
        AND email LIKE '%' || #{Email} || '%'
      </if>
      <if test="IsActive != null">
        AND is_active = #{IsActive}
      </if>
      <if test="Ids != null and Ids.Count > 0">
        AND id IN
        <foreach collection="Ids" item="id" open="(" separator="," close=")">
          #{id}
        </foreach>
      </if>
    </where>
  </select>

  <!--
    ==========================================
    쿼리 7: 사용자 등록 (INSERT)
    ==========================================

    【 사용 목적 】
    - 새로운 사용자 추가
    - 회원가입, 관리자 생성 등

    【 SQL 문법 】
    - INSERT INTO: 테이블에 데이터 삽입
    - (컬럼1, 컬럼2, ...): 삽입할 컬럼 목록
    - VALUES (값1, 값2, ...): 삽입할 값

    【 파라미터 바인딩 】
    - #{UserName}: User 객체의 UserName 속성
    - #{Email}: User 객체의 Email 속성
    - 객체의 속성명과 정확히 일치해야 함 (대소문자 구분)

    【 자동 생성 ID 】
    - PostgreSQL: RETURNING id
    - MySQL: SELECT LAST_INSERT_ID()
    - SQL Server: SELECT SCOPE_IDENTITY()

    【 C# 사용 예시 】
    var user = new User
    {
        UserName = "john_doe",
        Email = "john@example.com",
        FullName = "John Doe",
        CreatedAt = DateTime.UtcNow,
        IsActive = true
    };
    int rowsAffected = _userMapper.Insert(user);

    Console.WriteLine($"{rowsAffected}건 삽입됨");

    【 트랜잭션 】
    - INSERT는 트랜잭션 필수
    - 실패 시 롤백 가능
    - 여러 INSERT를 하나의 트랜잭션으로 묶기 권장
  -->
  <insert id="Insert">
    INSERT INTO users (user_name, email, full_name, created_at, is_active)
    VALUES (#{UserName}, #{Email}, #{FullName}, #{CreatedAt}, #{IsActive})
  </insert>

  <!--
    ==========================================
    쿼리 8: 사용자 수정 (UPDATE)
    ==========================================

    【 사용 목적 】
    - 기존 사용자 정보 수정
    - 프로필 업데이트, 정보 변경 등

    【 SQL 문법 】
    - UPDATE: 테이블 데이터 수정
    - SET: 변경할 컬럼과 값
    - WHERE: 수정할 대상 지정 (필수!)

    【 WHERE 절 필수! 】
    [위험] WHERE 없이 UPDATE 실행 시:
    UPDATE users SET user_name = 'john'
    → 모든 사용자의 이름이 'john'으로 변경됨!

    [안전] WHERE 절 사용:
    UPDATE users SET user_name = 'john' WHERE id = 123
    → ID 123인 사용자만 변경됨

    【 updated_at 자동 갱신 】
    - updated_at = #{UpdatedAt}: C#에서 DateTime.UtcNow 전달
    - 또는 CURRENT_TIMESTAMP: DB 서버 시간 사용

    【 C# 사용 예시 】
    var user = _userMapper.GetById(123);
    user.FullName = "John Updated";
    user.UpdatedAt = DateTime.UtcNow;

    int rowsAffected = _userMapper.Update(user);
    if (rowsAffected == 0)
    {
        Console.WriteLine("수정 실패: 사용자 없음");
    }
  -->
  <update id="Update">
    UPDATE users
    SET user_name  = #{UserName},
        email      = #{Email},
        full_name  = #{FullName},
        updated_at = #{UpdatedAt}
    WHERE id = #{Id}
  </update>

  <!--
    ==========================================
    쿼리 9: 사용자 Soft Delete
    ==========================================

    【 Soft Delete란? 】
    - 실제로 삭제하지 않고 '삭제됨' 플래그만 설정
    - is_active = false로 변경 (비활성화)
    - 데이터 복구 가능

    【 Soft Delete vs Hard Delete 】

    Soft Delete (소프트 삭제):
    - 장점: 복구 가능, 감사 추적, 법적 요구사항 충족
    - 단점: 디스크 공간 사용, 쿼리 복잡도 증가
    - 사용 예: 사용자 계정, 주문, 게시글

    Hard Delete (하드 삭제):
    - 장점: 디스크 공간 절약, 쿼리 단순
    - 단점: 복구 불가능, GDPR 위반 가능성
    - 사용 예: 임시 데이터, 로그

    【 조회 시 주의사항 】
    Soft Delete 사용 시 모든 SELECT에 WHERE 조건 추가:
    SELECT * FROM users WHERE is_active = true

    【 C# 사용 예시 】
    // Soft Delete
    int rowsAffected = _userMapper.SoftDelete(123);

    // 복구 (별도 메서드 필요)
    UPDATE users SET is_active = true WHERE id = 123
  -->
  <update id="SoftDelete">
    UPDATE users
    SET is_active  = false,
        updated_at = CURRENT_TIMESTAMP
    WHERE id = #{Id}
  </update>

  <!--
    ==========================================
    쿼리 10: 사용자 Hard Delete
    ==========================================

    【 사용 목적 】
    - 데이터 완전 삭제 (복구 불가능)
    - 테스트 데이터 제거, GDPR 삭제 요청 등

    【 SQL 문법 】
    - DELETE FROM: 테이블에서 행 삭제
    - WHERE: 삭제할 대상 지정 (필수!)

    【 WHERE 절 필수! 】
    [위험] WHERE 없이 DELETE 실행 시:
    DELETE FROM users
    → 모든 사용자 삭제됨! (복구 불가능!)

    [안전] WHERE 절 사용:
    DELETE FROM users WHERE id = 123
    → ID 123인 사용자만 삭제됨

    【 외래키 제약 조건 】
    - 다른 테이블이 참조 중이면 삭제 실패
    - 예: users(id) ← orders(user_id)
    - 해결: CASCADE 설정 또는 수동 삭제

    【 트랜잭션 필수 】
    [비권장] 트랜잭션 없이 삭제:
    _userMapper.Delete(123);  // 실패 시 복구 불가

    [권장] 트랜잭션 사용:
    using var transaction = connection.BeginTransaction();
    try
    {
        _userMapper.Delete(123);
        transaction.Commit();
    }
    catch
    {
        transaction.Rollback();
        throw;
    }

    【 C# 사용 예시 】
    int rowsAffected = _userMapper.Delete(123);
    if (rowsAffected == 0)
    {
        Console.WriteLine("삭제 실패: 사용자 없음");
    }
    else
    {
        Console.WriteLine("영구 삭제됨 (복구 불가능)");
    }
  -->
  <delete id="Delete">
    DELETE FROM users WHERE id = #{Id}
  </delete>

</mapper>
